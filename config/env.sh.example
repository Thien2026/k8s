# Copy thành config/env.sh — file này dùng cho bootstrap script
# Không commit config/env.sh

DOMAIN="example.com"
LETSENCRYPT_EMAIL="admin@example.com"

# IP public VPS (Ingress / Let's Encrypt)
NODE_PUBLIC_IP="1.2.3.4"

# RKE2
RKE2_VERSION=""          # để trống = latest stable
RKE2_TOKEN=""            # single node có thể để trống; multi-node bắt buộc

# Helm chart versions (pin để tái sử dụng)
INGRESS_NGINX_CHART_VERSION="4.11.3"
CERT_MANAGER_CHART_VERSION="v1.16.2"
LONGHORN_CHART_VERSION="1.7.2"

# Domain con cho platform
RANCHER_HOST="rancher.${DOMAIN}"
HARBOR_HOST="harbor.${DOMAIN}"
ARGOCD_HOST="argocd.${DOMAIN}"
GRAFANA_HOST="grafana.${DOMAIN}"
DEMO_HOST="hello-dev.${DOMAIN}"
PLATFORM_HOST="platform.${DOMAIN}"

# Domain con cho app auto-hostname (portal-api AutoHostname).
# Ví dụ: my-shop-dev.platform.example.com
PLATFORM_DOMAIN="platform.${DOMAIN}"

# Quy ước DNS đầy đủ (engines, *.redis, ingress, Cloudflare): docs/DOMAIN-CONVENTIONS.md
# Template proxy CF + checklist record: config/domains.env.example

# Helm chart versions — platform engines
# Rancher chart — 2.14.x+ cho K8s >= 1.32 (RKE2 1.35)
RANCHER_CHART_VERSION="2.14.2"
HARBOR_CHART_VERSION="1.19.1"   # Harbor OSS 2.15.1
ARGOCD_CHART_VERSION="9.7.1"
PROMETHEUS_STACK_CHART_VERSION="69.2.4"
GRAFANA_ADMIN_USER="admin"
# Để trống = tự sinh khi cài monitoring addon
GRAFANA_ADMIN_PASSWORD=""
ARGOCD_NAMESPACE="argocd"
GITOPS_REPO_URL=""
GITOPS_REPO_BRANCH="main"
GITOPS_BASE_PATH="apps"
# PAT dùng cho GitHub Actions push tag vào repo GitOps (scope: repo).
# Lưu ý: token này được inject thành secret PLATFORM_GITOPS_TOKEN ở repo app khi sync workflow.
GITOPS_PUSH_TOKEN=""

# Harbor admin — để trống = tự sinh khi chạy bootstrap 10
HARBOR_ADMIN_PASSWORD=""

# GHCR — org/user GitHub cho image path ghcr.io/ORG/project
GHCR_ORG=""
# PAT pull image private trên cluster (scope read:packages). User = GitHub username sở hữu PAT.
GHCR_PULL_USER=""
GHCR_PULL_TOKEN=""

# GitHub OAuth — auto-deploy (Phase G)
# Tạo OAuth App: https://github.com/settings/developers
# Homepage: https://platform.${DOMAIN}
# Callback: https://platform.${DOMAIN}/api/v1/github/oauth/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Addon preflight — ngưỡng RAM/disk trước khi cài (MiB / GiB)
# ADDON_RANCHER_MIN_MEM_MB="2048"
# ADDON_RANCHER_MIN_DISK_GB="15"
# ADDON_HARBOR_MIN_MEM_MB="3072"
# ADDON_HARBOR_MIN_DISK_GB="40"
# ADDON_ARGOCD_MIN_MEM_MB="1536"
# ADDON_ARGOCD_MIN_DISK_GB="10"
# ADDON_MONITORING_MIN_MEM_MB="1536"
# ADDON_MONITORING_MIN_DISK_GB="12"

# PostgreSQL — metadata Platform Console (portal-api), KHÔNG phải DB app khách
POSTGRES_DB="platform"
POSTGRES_USER="platform"
POSTGRES_PASSWORD="change-me-strong-password"
POSTGRES_STORAGE_SIZE="8Gi"
POSTGRES_STORAGE_CLASS=""   # để trống = dùng StorageClass mặc định cluster

# Backup cluster (RKE2 etcd + config) — bootstrap 09c
BACKUP_DIR="/var/backups/platform-k8s"
BACKUP_CRON="0 3 * * *"           # 03:00 hàng ngày
BACKUP_RETENTION_DAYS="14"

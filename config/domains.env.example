# Copy / source cùng config/env.sh — quy ước hostname chuẩn cho cluster mới.
# Tài liệu đầy đủ: docs/DOMAIN-CONVENTIONS.md
# Cloudflare defaults: docs/CLOUDFLARE-INTEGRATION.md
#
# Thay ${DOMAIN}, ${NODE_PUBLIC_IP} bằng giá trị thật (hoặc source env.sh trước).

# --- Apex ---
DOMAIN="example.com"
NODE_PUBLIC_IP="1.2.3.4"

# --- Platform Console ---
PLATFORM_HOST="platform.${DOMAIN}"
PLATFORM_DOMAIN="platform.${DOMAIN}"

# --- Engines (bootstrap addons) ---
RANCHER_HOST="rancher.${DOMAIN}"
HARBOR_HOST="harbor.${DOMAIN}"
ARGOCD_HOST="argocd.${DOMAIN}"
GRAFANA_HOST="grafana.${DOMAIN}"
DEMO_HOST="hello-dev.${DOMAIN}"

# --- Derived (không set tay — portal / doc dùng pattern) ---
# INGRESS_CNAME_TARGET="ingress.${DOMAIN}"
# APP_DEV_HOST="{slug}-dev.${PLATFORM_DOMAIN}"
# APP_PROD_HOST="{slug}-prod.${PLATFORM_DOMAIN}"
# REDIS_ZONE="redis.${DOMAIN}"
# REDIS_DEV_HOST="{slug}-redis-dev.redis.${DOMAIN}"

# --- Cloudflare proxy mode (true = proxied orange cloud) ---
# Dùng khi implement CF integration — Apply defaults đọc bảng này.
CF_PROXY_PLATFORM="true"
CF_PROXY_APP_WILDCARD="true"      # *.platform.${DOMAIN}
CF_PROXY_GRAFANA="true"
CF_PROXY_RANCHER="false"
CF_PROXY_HARBOR="false"
CF_PROXY_ARGOCD="false"
CF_PROXY_INGRESS="false"          # CNAME target — luôn DNS only
CF_PROXY_REDIS_WILDCARD="false"   # TCP — bắt buộc DNS only

# --- DNS record checklist (comment — tạo tay hoặc qua CF API) ---
# platform.${DOMAIN}           A  ${NODE_PUBLIC_IP}
# *.platform.${DOMAIN}         A  ${NODE_PUBLIC_IP}
# rancher.${DOMAIN}            A  ${NODE_PUBLIC_IP}
# harbor.${DOMAIN}             A  ${NODE_PUBLIC_IP}
# argocd.${DOMAIN}             A  ${NODE_PUBLIC_IP}
# grafana.${DOMAIN}            A  ${NODE_PUBLIC_IP}
# ingress.${DOMAIN}            A  ${NODE_PUBLIC_IP}
# *.redis.${DOMAIN}            A  ${NODE_PUBLIC_IP}

# Copy thành config/platform-auth.env — không commit
# Sinh JWT_SECRET: openssl rand -base64 48

JWT_SECRET=""

# Tài khoản bootstrap (chỉ dùng lần đầu seed)
PLATFORM_ADMIN_EMAIL="admin@platform.local"
PLATFORM_ADMIN_PASSWORD="Thien@2026"
PLATFORM_ADMIN_NAME="Platform Admin"

# Đăng nhập nhanh trên UI (tạm — set QUICK_LOGIN_ENABLED=false để tắt)
QUICK_LOGIN_ENABLED="true"

# Passphrase lớp 2 khi sửa Platform Policy (không phải mật khẩu login)
POLICY_UNLOCK_PASSPHRASE="Thien123!@#"

# Tech lead mẫu (optional)
PLATFORM_LEAD_EMAIL=""
PLATFORM_LEAD_PASSWORD=""
PLATFORM_LEAD_NAME="Technical Lead"
